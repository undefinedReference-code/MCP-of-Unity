{
  "domain": "particles",
  "templates": [
    {
      "title": "Set Emission Rate",
      "when": "Need to increase or reduce particles spawned per second.",
      "keywords": ["emission", "rate", "spawn"],
      "requestTemplate": {
        "mode": "set",
        "targetType": "UnityEngine.ParticleSystem+EmissionModule",
        "member": "rateOverTimeMultiplier",
        "args": [35.0],
        "objectSelector": {
          "gameObjectName": "VFX_Emitter"
        },
        "dryRun": false
      }
    },
    {
      "title": "Set Start Lifetime",
      "when": "Need particles to stay longer or vanish faster.",
      "keywords": ["lifetime", "duration", "life"],
      "requestTemplate": {
        "mode": "set",
        "targetType": "UnityEngine.ParticleSystem+MainModule",
        "member": "startLifetime",
        "args": [2.5],
        "objectSelector": {
          "gameObjectName": "VFX_Emitter"
        },
        "dryRun": false
      }
    },
    {
      "title": "Play Particle System",
      "when": "Need to trigger particles immediately.",
      "keywords": ["play", "start", "trigger"],
      "requestTemplate": {
        "mode": "invoke",
        "targetType": "UnityEngine.ParticleSystem",
        "member": "Play",
        "args": [],
        "objectSelector": {
          "gameObjectName": "VFX_Emitter"
        },
        "dryRun": false
      }
    }
  ]
}

